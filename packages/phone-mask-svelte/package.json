{
  "name": "@desource/phone-mask-svelte",
  "version": "0.3.0",
  "description": "Svelte component for international phone number masking. Powered by @desource/phone-mask with Google libphonenumber sync.",
  "keywords": [
    "svelte",
    "phone",
    "mask",
    "input",
    "component",
    "international",
    "libphonenumber",
    "country-code",
    "phone-number",
    "formatting",
    "validation",
    "typescript"
  ],
  "author": "Stefan Popov <stefan@desource-labs.org>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeSource-Labs/phone-mask.git",
    "directory": "packages/phone-mask-svelte"
  },
  "bugs": {
    "url": "https://github.com/DeSource-Labs/phone-mask/issues"
  },
  "homepage": "https://github.com/DeSource-Labs/phone-mask/tree/main/packages/phone-mask-svelte#readme",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo test-results",
    "dev": "vite demo",
    "build": "pnpm build-lib && pnpm build-types",
    "build-lib": "vite build",
    "build-types": "tsc --project tsconfig.build.json",
    "typecheck": "svelte-check --tsconfig tsconfig.json",
    "test:e2e": "playwright test"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@desource/phone-mask": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0"
  }
}
