{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/types",
    "tsBuildInfoFile": "./tsconfig.build.tsbuildinfo",
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowArbitraryExtensions": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
